# Puerto del backend
PORT=8787

# Wallets admin separadas por coma. Esta wallet viene del index original.
ADMIN_WALLETS=UQB9uFaCgM5HVntXHe-mq3xYiYjcLEzvgnZUCffNC5DR-7vg

# Cambiar por un secreto largo y privado en producción.
ADMIN_TOKEN_SECRET=CAMBIA_ESTE_SECRETO_LARGO_EN_PRODUCCION

# Tiempo de vida del payload TON proof en segundos.
TON_PROOF_TTL_SECONDS=300

# Duración de sesión admin en segundos.
ADMIN_SESSION_TTL_SECONDS=86400

# Orígenes permitidos para CORS. Ejemplos:
# CORS_ORIGIN=https://tuusuario.github.io,https://tudominio.com,http://localhost:8080
CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080

# Dominios válidos dentro del TON proof, sin protocolo.
# Ejemplos: tuusuario.github.io,tudominio.com,localhost:8080,127.0.0.1:8080
TON_PROOF_ALLOWED_DOMAINS=localhost:8080,127.0.0.1:8080

# USDT Jetton TON mainnet
USDT_MASTER_ADDRESS=EQCxE6mUtQJKFnGfaROTKOt1lZbDiiX1kCixRv7Nw2Id_sDs
INVOICE_WALLET_ADDRESS=EQD3u6SffmoBUVzumsMpfG5qzfvYrASNiwW6IRPVqQmv9MIs
TONCENTER_ENDPOINT=https://toncenter.com/api/v2/jsonRPC
# Opcional, recomendado en producción para evitar rate limits
TONCENTER_API_KEY=

# Wallet pagadora para retiros automáticos (24 palabras). NO subir valores reales a GitHub.
# Configurar solo en Render Environment.
PAYOUT_WALLET_MNEMONIC=
PAYOUT_WALLET_VERSION=v4r2
