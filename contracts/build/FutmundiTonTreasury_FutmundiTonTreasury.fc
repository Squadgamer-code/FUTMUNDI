    }
    ;; Receive "Tournament" message
    if (text_op == 0x91cc3c51d91d613a15a37022955e4094cd88c7951001cb87fbe235bf684d9fda) {
        throw_unless(23306, ($Context$_get_value(__tact_context_get()) > 0));
        $FutmundiTonTreasury$_contract_store(($self'owner, $self'feeWallet, $self'paused, $self'feeBps, $self'fixedFee, $self'minWithdraw, $self'maxWithdraw));
        return ();
    }
    ;; Throw if not handled
    throw(130);
}
